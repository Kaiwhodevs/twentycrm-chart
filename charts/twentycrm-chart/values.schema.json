{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "twentycrm-chart values",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": { "type": "array" },
        "storageClass": { "type": "string" }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "namespaceOverride": { "type": "string" },
    "clusterDomain": { "type": "string" },
    "commonLabels": { "type": "object" },
    "commonAnnotations": { "type": "object" },
    "extraDeploy": { "type": "array" },
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      },
      "required": ["repository"]
    },
    "imagePullSecrets": { "type": "array" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" }
      }
    },
    "server": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0 },
        "service": { "type": "object" },
        "autoscaling": { "type": "object" },
        "pdb": { "type": "object" }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "serverUrl": { "type": "string" },
        "nodePort": { "type": ["integer", "string"] },
        "disableDbMigrations": { "type": "string" },
        "disableCronJobsRegistration": { "type": "string" },
        "storage": { "type": "object" }
      }
    },
    "extraEnv": { "type": "object" },
    "secret": {
      "type": "object",
      "properties": {
        "appSecret": { "type": "string" },
        "encryptionKey": { "type": "string" },
        "fallbackEncryptionKey": { "type": "string" },
        "secretRef": { "type": "string" },
        "secretRefKey": { "type": "object" },
        "db": {
          "type": "object",
          "properties": {
            "password": { "type": "string" },
            "secretRef": { "type": "string" },
            "secretRefKey": { "type": "object" }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "object" },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "database": { "type": "string" }
          }
        },
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "persistence": { "type": "object" }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "database": { "type": "string" },
        "user": { "type": "string" },
        "ssl": { "type": "boolean" },
        "secretRef": { "type": "string" },
        "secretRefKey": { "type": "object" }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "object" },
        "maxmemoryPolicy": { "type": "string" },
        "service": { "type": "object" },
        "persistence": { "type": "object" }
      }
    },
    "externalRedis": {
      "type": "object",
      "properties": { "url": { "type": "string" } }
    },
    "localStorage": { "type": "object" },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    }
  }
}
